PORT=3000

# Desenvolvimento local: caminho para o JSON baixado do Firebase.
FIREBASE_SERVICE_ACCOUNT=C:\firebase\qrcode-lab-service-account.json

# Necessario quando o Firestore nao usa o banco "(default)".
FIREBASE_DATABASE_ID=qrcodelab

# Deploy online: use Base64 em vez de enviar o arquivo JSON para o GitHub.
# FIREBASE_SERVICE_ACCOUNT_BASE64=cole_aqui_o_json_em_base64

# Recomendado no deploy online. O usuario do painel sera "admin".
# ADMIN_PASSWORD=defina_uma_senha_forte

# Opcional para gerar os QR Codes sem informar a URL no comando.
# PUBLIC_URL=https://seu-projeto.onrender.com
